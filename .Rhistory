crs(slope) <- "EPSG:4326"   # only do this if you KNOW it's lon/lat degrees
# 2) Project to Web Mercator for leaflet
slope_3857 <- project(slope, "EPSG:3857")
class(slope)
crs(slope) <- CRS("+init=epsg:4326")
crs(slope)
slope_3857 <- project(slope, "EPSG:3857")
