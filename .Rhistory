twi <- rast("images/geo_layers/TWI.tif")
dir.create("images/geo_layers/clean", showWarnings = FALSE)
# -------- SLOPE --------
writeRaster(
slope,
"images/geo_layers/clean/Slope_clean.tif",
overwrite = TRUE,
gdal = c("COMPRESS=LZW")
)
slope <- rast("images/geo_layers/clean/Slope_clean.tif")
# -------- RADPOT --------
writeRaster(
radpot,
"images/geo_layers/clean/radpot_clean.tif",
overwrite = TRUE,
gdal = c("COMPRESS=LZW")
)
radpot <- rast("images/geo_layers/clean/radpot_clean.tif")
# -------- TWI --------
writeRaster(
twi,
"images/geo_layers/clean/TWI_clean.tif",
overwrite = TRUE,
gdal = c("COMPRESS=LZW")
)
twi <- rast("images/geo_layers/clean/TWI_clean.tif")
dotmap <- leaflet(centroid)%>%
addProviderTiles("CartoDB.Positron") %>%
