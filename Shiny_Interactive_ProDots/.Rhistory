web_mercator <- "+proj=merc +a=6378137 +b=6378137 +lat_ts=0.0 +lon_0=0.0 +x_0=0.0 +y_0=0 +k=1.0 +units=m +nadgrids=@null +wktext +no_defs"
# 2. Force assign this string to your rasters
# This bypasses the "empty srs" error by giving it a manual definition
crs(slope) <- wgs84_string
crs(twi) <- wgs84_string
crs(radpot) <- wgs84_string
slope  <- terra::project(slope, web_mercator)
radpot <- terra::project(radpot, web_mercator)
twi    <- terra::project(twi, web_mercator)
slope  <- terra::project(slope, web_mercator)
